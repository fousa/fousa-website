{
  "name": "fousa",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "seed:stack-tags": "tsx -r dotenv/config scripts/seed-stack-tags.ts dotenv_config_path=.env.local",
    "backup": "sanity dataset export production backups/dataset-$(date +%Y%m%d-%H%M%S).tar.gz",
    "migrate:content": "tsx -r dotenv/config scripts/migrate-content.ts dotenv_config_path=.env.local",
    "migrate:content:dry": "tsx -r dotenv/config scripts/migrate-content.ts dotenv_config_path=.env.local --dry-run",
    "publish:drafts": "tsx -r dotenv/config scripts/publish-drafts.ts dotenv_config_path=.env.local",
    "publish:drafts:dry": "tsx -r dotenv/config scripts/publish-drafts.ts dotenv_config_path=.env.local --dry-run",
    "schema:extract": "sanity schema extract --path=./schema.json",
    "typegen": "pnpm schema:extract && sanity typegen generate"
  },
  "dependencies": {
    "@portabletext/react": "^6.2.0",
    "@sanity/client": "^7.22.0",
    "@sanity/vision": "^5.26.0",
    "@vercel/analytics": "^2.0.1",
    "next": "16.2.6",
    "next-sanity": "^13.0.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanity": "^5.26.0",
    "styled-components": "^6.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.2.0",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "gray-matter": "^4.0.3",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
